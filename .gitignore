
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shadow Download - Multiplataforma</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .bg-shadow-pattern {
            background-color: #0f172a;
            background-image: radial-gradient(circle at 50% 0%, #1e293b 0%, transparent 70%);
        }
        .tab-transition {
            transition: all 0.3s ease-in-out;
        }
    </style>
</head>
<body class="bg-shadow-pattern min-h-screen flex flex-col font-sans text-slate-200 selection:bg-pink-500 selection:text-white">

    <main class="flex-grow flex items-center justify-center p-4">
        <div class="bg-slate-900/80 backdrop-blur-md rounded-[2.5rem] shadow-2xl w-full max-w-lg p-6 sm:p-10 border border-slate-700/50">
            
            <!-- Encabezado -->
            <div class="text-center mb-8">
                <div id="main-icon-container" class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-slate-800 to-black text-white mb-4 shadow-[0_0_20px_rgba(236,72,153,0.3)] border border-slate-700 tab-transition">
                    <svg id="main-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-pink-500 tab-transition">
                        <path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle>
                    </svg>
                </div>
                <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white mb-2">
                    Shadow <span id="title-accent" class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500 tab-transition">Download</span>
                </h1>
                <p class="text-sm text-slate-400">Descarga contenido en máxima calidad, sin rastro.</p>
            </div>

            <!-- Selector de Plataforma -->
            <div class="flex p-1 mb-6 space-x-1 bg-slate-800/60 rounded-2xl border border-slate-700/50 backdrop-blur-sm">
                <button onclick="setPlatform('tiktok')" id="tab-tiktok" class="w-1/2 py-3 text-sm font-bold rounded-xl bg-slate-700 text-white shadow-lg tab-transition flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
                    TikTok
                </button>
                <button onclick="setPlatform('instagram')" id="tab-instagram" class="w-1/2 py-3 text-sm font-bold rounded-xl text-slate-400 hover:text-white hover:bg-slate-700/50 tab-transition flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    Instagram
                </button>
            </div>

            <!-- Formulario -->
            <div class="space-y-5">
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none transition-colors text-slate-500" id="input-icon-wrapper">
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                        </svg>
                    </div>
                    <input type="url" id="video-url" class="block w-full pl-12 pr-4 py-4 bg-slate-800/50 border border-slate-700 rounded-2xl text-base text-white placeholder-slate-500 focus:ring-2 focus:ring-pink-500 focus:border-pink-500 focus:bg-slate-800 transition-all outline-none" placeholder="Pega tu enlace de TikTok (vt.tiktok...)">
                </div>

                <button id="download-btn" onclick="handleDownload()" class="w-full flex items-center justify-center gap-2 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 text-white font-semibold py-4 px-8 rounded-2xl transition-all shadow-[0_0_15px_rgba(236,72,153,0.4)] hover:shadow-[0_0_25px_rgba(236,72,153,0.6)] active:scale-[0.98]">
                    <span id="btn-text">Procesar TikTok</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </button>
            </div>

            <!-- Área de Mensajes de Error -->
            <div id="error-message" class="hidden mt-6 p-4 bg-red-900/30 border border-red-500/50 text-red-200 rounded-2xl text-sm transition-all overflow-x-auto backdrop-blur-sm">
            </div>

            <!-- Estado de Carga -->
            <div id="loading-state" class="hidden mt-8 flex-col items-center justify-center space-y-4">
                <div class="relative w-12 h-12">
                    <div class="absolute inset-0 rounded-full border-4 border-slate-700"></div>
                    <div id="spinner-color" class="absolute inset-0 rounded-full border-4 border-pink-500 border-t-transparent animate-spin"></div>
                </div>
                <p id="loading-text" class="text-sm font-medium text-slate-400 animate-pulse">Analizando enlace...</p>
            </div>

            <!-- Tarjeta de Resultado -->
            <div id="result-state" class="hidden mt-8 bg-slate-800/80 rounded-3xl p-4 border border-slate-700 shadow-inner">
                <div class="flex flex-col sm:flex-row gap-5 items-center">
                    
                    <div class="w-full sm:w-1/3 aspect-video sm:aspect-square bg-slate-900 rounded-2xl overflow-hidden relative flex-shrink-0 border border-slate-700/50 group">
                        <img id="result-thumb" src="" alt="Miniatura" class="w-full h-full object-cover opacity-90 transition-opacity group-hover:opacity-100">
                        <div id="watermark-badge" class="absolute top-2 right-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded-lg text-[10px] font-bold text-pink-400 uppercase tracking-wider border border-white/10">
                            Limpio
                        </div>
                    </div>
                    
                    <div class="w-full sm:w-2/3 space-y-3">
                        <h3 id="result-title" class="font-semibold text-white line-clamp-2 text-sm leading-snug"></h3>
                        <div class="flex items-center gap-2">
                            <span class="flex h-2 w-2 relative">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                            </span>
                            <p id="result-quality" class="text-xs text-slate-300 font-medium"></p>
                        </div>
                        
                        <div class="pt-2">
                            <a id="btn-download-video" href="#" target="_blank" rel="noopener noreferrer" class="w-full flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 text-sm font-bold py-3 px-4 rounded-xl transition-colors shadow-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                                </svg>
                                Descargar MP4
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="w-full border-t border-slate-800 bg-slate-900/50 backdrop-blur-sm mt-auto">
        <div class="max-w-4xl mx-auto px-6 py-8 text-center text-xs text-slate-500 uppercase tracking-widest">
            &copy; 2026 Shadow Download Multiplataforma.
        </div>
    </footer>

    <script>
        // ESTADO GLOBAL
        let currentPlatform = 'tiktok';

        // CREDENCIALES
        const RAPIDAPI_KEY = 'a3065b014fmsh6b618f7f41feb94p130f1ajsn0f66c30ecc69'; 

        // CONFIG TIKTOK
        const TK_HOST_VIDEO = 'tiktok-max-quality.p.rapidapi.com'; 
        const TK_URL_VIDEO = `https://${TK_HOST_VIDEO}/download/`; 
        const TK_URL_META = 'https://www.tikwm.com/api/';

        // CONFIG INSTAGRAM
        const IG_HOST = 'instagram-reels-downloader-api.p.rapidapi.com'; 
        const IG_URL = `https://${IG_HOST}/download`; 

        // ==========================================
        // CONTROL DE INTERFAZ
        // ==========================================
        function setPlatform(platform) {
            currentPlatform = platform;
            
            const tabTk = document.getElementById('tab-tiktok');
            const tabIg = document.getElementById('tab-instagram');
            const inputUrl = document.getElementById('video-url');
            const mainIcon = document.getElementById('main-icon');
            const iconContainer = document.getElementById('main-icon-container');
            const btn = document.getElementById('download-btn');
            const spinner = document.getElementById('spinner-color');
            const badge = document.getElementById('watermark-badge');
            
            document.getElementById('result-state').classList.add('hidden');
            document.getElementById('error-message').classList.add('hidden');
            inputUrl.value = '';

            if (platform === 'tiktok') {
                tabTk.className = "w-1/2 py-3 text-sm font-bold rounded-xl bg-slate-700 text-white shadow-lg tab-transition flex items-center justify-center gap-2";
                tabIg.className = "w-1/2 py-3 text-sm font-bold rounded-xl text-slate-400 hover:text-white hover:bg-slate-700/50 tab-transition flex items-center justify-center gap-2";
                inputUrl.placeholder = "Pega tu enlace de TikTok...";
                document.getElementById('btn-text').textContent = "Procesar TikTok";
                
                btn.className = "w-full flex items-center justify-center gap-2 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 text-white font-semibold py-4 px-8 rounded-2xl transition-all shadow-[0_0_15px_rgba(236,72,153,0.4)] hover:shadow-[0_0_25px_rgba(236,72,153,0.6)] active:scale-[0.98]";
                iconContainer.className = "inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-slate-800 to-black text-white mb-4 shadow-[0_0_20px_rgba(236,72,153,0.3)] border border-slate-700 tab-transition";
                mainIcon.className = "text-pink-500 tab-transition";
                spinner.className = "absolute inset-0 rounded-full border-4 border-pink-500 border-t-transparent animate-spin";
                badge.className = "absolute top-2 right-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded-lg text-[10px] font-bold text-pink-400 uppercase tracking-wider border border-white/10";
                mainIcon.innerHTML = `<path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle>`;
            } else {
                tabIg.className = "w-1/2 py-3 text-sm font-bold rounded-xl bg-slate-700 text-white shadow-lg tab-transition flex items-center justify-center gap-2";
                tabTk.className = "w-1/2 py-3 text-sm font-bold rounded-xl text-slate-400 hover:text-white hover:bg-slate-700/50 tab-transition flex items-center justify-center gap-2";
                inputUrl.placeholder = "Pega tu Reel de Instagram...";
                document.getElementById('btn-text').textContent = "Procesar Instagram";
                
                btn.className = "w-full flex items-center justify-center gap-2 bg-gradient-to-r from-orange-500 via-pink-500 to-purple-500 hover:from-orange-400 hover:via-pink-400 hover:to-purple-400 text-white font-semibold py-4 px-8 rounded-2xl transition-all shadow-[0_0_15px_rgba(236,72,153,0.4)] hover:shadow-[0_0_25px_rgba(236,72,153,0.6)] active:scale-[0.98]";
                iconContainer.className = "inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-slate-800 to-black text-white mb-4 shadow-[0_0_20px_rgba(249,115,22,0.3)] border border-slate-700 tab-transition";
                mainIcon.className = "text-orange-500 tab-transition";
                spinner.className = "absolute inset-0 rounded-full border-4 border-orange-500 border-t-transparent animate-spin";
                badge.className = "absolute top-2 right-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded-lg text-[10px] font-bold text-orange-400 uppercase tracking-wider border border-white/10";
                mainIcon.innerHTML = `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>`;
            }
        }

        async function handleDownload() {
            const urlInput = document.getElementById('video-url').value.trim();
            const errorMsg = document.getElementById('error-message');
            const loadingState = document.getElementById('loading-state');
            const resultState = document.getElementById('result-state');
            const btn = document.getElementById('download-btn');

            errorMsg.classList.add('hidden');
            resultState.classList.add('hidden');
            if (!urlInput) return;

            btn.disabled = true;
            loadingState.classList.remove('hidden');
            loadingState.classList.add('flex');

            try {
                if (currentPlatform === 'tiktok') {
                    await downloadTikTok(urlInput);
                } else {
                    await downloadInstagram(urlInput);
                }
            } catch (error) {
                loadingState.classList.add('hidden');
                loadingState.classList.remove('flex');
                errorMsg.innerHTML = error.message; 
                errorMsg.classList.remove('hidden');
            } finally {
                btn.disabled = false;
            }
        }

        // ==========================================
        // MOTOR TIKTOK (CON FALLBACK AUTOMÁTICO)
        // ==========================================
        async function downloadTikTok(url) {
            document.getElementById('loading-text').textContent = "Procesando motores híbridos...";
            
            // Promesa 1: Motor Principal 4K (RapidAPI)
            const fetchVideo = fetch(`${TK_URL_VIDEO}?url=${encodeURIComponent(url)}`, {
                method: 'GET',
                headers: { 'x-rapidapi-key': RAPIDAPI_KEY, 'x-rapidapi-host': TK_HOST_VIDEO }
            }).then(res => res.json()).catch(err => null); // Si falla, no rompemos todo

            // Promesa 2: Motor Secundario (TikWM) - ¡Súper estable!
            const fetchMeta = fetch(`${TK_URL_META}?url=${encodeURIComponent(url)}`)
                .then(res => res.json())
                .catch(err => null);

            // Ejecutar al mismo tiempo
            const [videoResult, metaResult] = await Promise.allSettled([fetchVideo, fetchMeta]);

            // Variables para recolectar lo que encontremos
            let finalVideoUrl = null;
            let finalQuality = 'HD (Respaldo)';
            let finalCover = 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=300&q=80';
            let finalTitle = 'Video de TikTok';
            let isCarousel = false;

            // 1. Extraer datos del Motor Secundario (TikWM)
            let metaData = null;
            if (metaResult.status === 'fulfilled' && metaResult.value?.code === 0) {
                metaData = metaResult.value.data;
                if (metaData.cover) finalCover = metaData.cover;
                if (metaData.title) finalTitle = metaData.title;
                
                // Revisar si es una galería de fotos en lugar de video
                if (metaData.images && metaData.images.length > 0) {
                    isCarousel = true;
                }
            }

            // 2. Extraer URL de video de Motor Principal (RapidAPI)
            if (videoResult.status === 'fulfilled' && videoResult.value) {
                finalVideoUrl = videoResult.value.download_url || videoResult.value.off_url;
                if (videoResult.value.quality) {
                    finalQuality = videoResult.value.quality;
                }
            }

            // 3. FALLBACK: Si RapidAPI falló o no dio enlace, usamos el de TikWM
            if (!finalVideoUrl && metaData && metaData.play) {
                finalVideoUrl = metaData.play;
                finalQuality = 'HD (Motor Respaldo)';
            }

            // 4. Verificación final de errores
            if (!finalVideoUrl) {
                if (isCarousel) {
                    throw new Error(`
                        <strong class="text-white block mb-1">¡Aviso! Esto es una galería de fotos.</strong>
                        <span class="text-slate-300">El enlace pertenece a un carrusel de imágenes de TikTok. Nuestra herramienta actualmente solo soporta la extracción de videos MP4.</span>
                    `);
                } else {
                    throw new Error(`
                        <strong class="text-white block mb-1">No se pudo extraer el video.</strong>
                        <span class="text-slate-300">Ambos motores fallaron. Verifica que el video sea público, no haya sido eliminado o que el enlace esté bien copiado.</span>
                    `);
                }
            }

            renderResult(finalCover, finalTitle, `Calidad: ${finalQuality}`, finalVideoUrl);
        }

        // ==========================================
        // MOTOR INSTAGRAM 
        // ==========================================
        async function downloadInstagram(url) {
            document.getElementById('loading-text').textContent = "Extrayendo Reel de Instagram...";
            
            const options = {
                method: 'GET',
                headers: {
                    'x-rapidapi-key': RAPIDAPI_KEY,
                    'x-rapidapi-host': IG_HOST,
                    'Content-Type': 'application/json'
                }
            };

            const apiUrl = `${IG_URL}?url=${encodeURIComponent(url)}`;
            const response = await fetch(apiUrl, options);
            
            if (!response.ok) {
                if (response.status === 403) {
                    throw new Error("<strong class='text-white'>Aviso 403:</strong> Debes ir a RapidAPI, buscar 'Instagram Reels Downloader API' y suscribirte al plan gratis.");
                }
                throw new Error(`Error del servidor IG: ${response.status}`);
            }

            const result = await response.json();
            
            let videoUrl = result?.data?.video_url || result?.video_url || result?.url || result?.data?.url || result?.download_url || (Array.isArray(result.data) && result.data[0]?.video_url);

            if (!videoUrl) {
                const jsonString = JSON.stringify(result, null, 2);
                throw new Error(`
                    <strong class="text-white block mb-2">Formato inesperado:</strong>
                    <pre class="bg-black/50 text-pink-300 p-3 rounded-lg text-[10px] overflow-auto text-left border border-white/10 h-32">${jsonString}</pre>
                `);
            }

            let coverImg = result?.data?.thumbnail_url || result?.thumbnail_url || result?.cover || result?.data?.thumbnail || 'https://images.unsplash.com/photo-1611262588024-d12430b98920?w=300&q=80'; 
            let title = result?.data?.title || result?.title || result?.data?.description || 'Reel de Instagram';

            renderResult(coverImg, title, "Calidad: Alta (Reel)", videoUrl);
        }

        // ==========================================
        // RENDERIZAR
        // ==========================================
        function renderResult(cover, title, quality, downloadUrl) {
            document.getElementById('result-thumb').src = cover;
            document.getElementById('result-title').textContent = title;
            document.getElementById('result-quality').textContent = quality;
            document.getElementById('btn-download-video').href = downloadUrl;
            
            document.getElementById('loading-state').classList.add('hidden');
            document.getElementById('loading-state').classList.remove('flex');
            document.getElementById('result-state').classList.remove('hidden');
        }

        document.getElementById('video-url').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') handleDownload();
        });
    </script>
</body>
</html>


